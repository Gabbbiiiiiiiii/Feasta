NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Public reCAPTCHA Enterprise site key. This is not a secret. Never place a
# reCAPTCHA secret key or service-account credential in NEXT_PUBLIC_*.
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# Server-only Firebase Admin configuration. Never prefix secrets with
# NEXT_PUBLIC_. Production uses Application Default Credentials supplied by
# the hosting environment; do not commit a service-account JSON file.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_STORAGE_BUCKET=
# Vercel: store these as encrypted server-only environment variables. Keep
# them unprefixed; never place either value in NEXT_PUBLIC_* variables.
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Local emulator settings (server-side). Firebase Admin SDK reads the host
# variables directly. Keep these unset in production.
USE_FIREBASE_EMULATORS=true
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Comma-separated, exact origins allowed to perform cookie-authenticated
# mutations. Required in production; include scheme and port when non-default.
WEB_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
