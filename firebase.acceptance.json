{
  "functions": [{
    "source": "functions",
    "codebase": "default",
    "ignore": ["node_modules", ".git", "firebase-debug.log", "*.local"]
  }],
  "firestore": {
    "rules": "firebase/firestore.rules",
    "indexes": "firebase/firestore.indexes.json"
  },
  "storage": {"rules": "firebase/storage.rules"},
  "hosting": {
    "public": "firebase/hosting",
    "cleanUrls": true,
    "rewrites": [{
      "source": "/api/health",
      "function": {
        "functionId": "healthCheck",
        "region": "asia-southeast1"
      }
    }]
  },
  "emulators": {
    "auth": {"host": "127.0.0.1", "port": 59099},
    "firestore": {"host": "127.0.0.1", "port": 58080},
    "functions": {"host": "127.0.0.1", "port": 55001},
    "storage": {"host": "127.0.0.1", "port": 59199},
    "hosting": {"host": "127.0.0.1", "port": 55000},
    "hub": {"host": "127.0.0.1", "port": 54401},
    "logging": {"host": "127.0.0.1", "port": 54501},
    "ui": {"enabled": false},
    "singleProjectMode": true
  }
}
